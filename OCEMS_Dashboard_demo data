// Timing variables
unsigned long lastTime = 0;
const unsigned long interval = 60000; // 2 Minutes

WiFiClientSecure net;
PubSubClient client(net);

void setup_wifi() {
  Serial.print("Connecting WiFi...");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500); Serial.print(".");
  }
  Serial.println("Connected!");
}

void connectAWS() {
  net.setCACert(root_ca);
  net.setCertificate(device_cert);
  net.setPrivateKey(private_key);
  client.setServer(mqtt_server, mqtt_port);

  while (!client.connected()) {
    Serial.print("Connecting MQTT...");
    if (client.connect("ESP32_SN00012")) {
      Serial.println("Connected!");
    } else {
      Serial.print("Failed: ");
      Serial.println(client.state());
      delay(2000);
    }
  }
}

void setup() {
  Serial.begin(115200);
  setup_wifi();
  connectAWS();
  
  // Trick the timer so it sends the first data 1 second after connecting
  lastTime = millis() - (interval - 1000); 
  
  randomSeed(analogRead(0));
}

void loop() {
  if (!client.connected()) connectAWS();
  client.loop();

  unsigned long currentTime = millis();

  // Trigger Logic: 1st send after 1s, then every 2 mins
  if (currentTime - lastTime >= interval) {
    lastTime = currentTime; 

    Serial.println("published data..");

    StaticJsonDocument<300> doc;
    doc["signature"] = "test-signature-xyz";
    doc["pH"] = random(60, 81) / 10.0;
    doc["EC"] = random(300, 801);
    doc["TDS"] = random(400, 601);
    doc["BOD"] = random(20, 40) / 10.0;
    doc["orp"] = random(150, 401);

    //  doc["COD"] = random(15, 25);
    //  doc["TOC"] = random(40, 60) / 10.0;
    //doc["Turbidity"] = random(10, 30) / 10.0;
    //doc["Temp1"] = random(250, 300) / 10.0;
    doc["Salinity"] = random(10, 50) / 100.0;

    char jsonBuffer[512];
    serializeJson(doc, jsonBuffer);

    if (client.publish(topic, jsonBuffer)) {
      Serial.println("Data Published Successfully:");
      Serial.println(jsonBuffer);
    } else {
      Serial.println("Error: Publish failed");
    }
  }
}
